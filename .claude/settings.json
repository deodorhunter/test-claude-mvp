{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "env": {}
    },
    "serena": {
      "type": "sse",
      "url": "http://localhost:9121/sse"
    },
    "codebase-memory-mcp": {
      "type": "stdio",
      "command": "bash",
      "args": ["infra/scripts/cbm-mcp.sh"],
      "env": {
        "NAVIGATION_BACKEND": "both"
      }
    }
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-prompt.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/tool-preference-inject.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-exploration.sh"
          }
        ]
      },
      {
        "matcher": "mcp__serena__.*|mcp__codebase-memory-mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/tool-routing-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-tool-truncate.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/log-subagent-tokens.sh"
          }
        ]
      }
    ]
  },
  "commands": [
    {
      "name": "deliberate",
      "description": "Run RALPLAN deliberation for HIGH-complexity US before delegation. Loads .claude/skills/ralplan-deliberation.md.",
      "prompt": "Load and follow the deliberation skill at .claude/skills/ralplan-deliberation.md for the current HIGH-complexity User Story."
    },
    {
      "name": "update-memories",
      "description": "Audit and refresh stale Serena memories. Run after phase gates or significant refactors.",
      "prompt": "Load and follow the skill at .claude/skills/update-memories.md"
    }
  ],
  "enabledMcpjsonServers": [
    "context7",
    "serena",
    "codebase-memory-mcp"
  ]
}
