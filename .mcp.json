{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "env": {}
    },
    "serena": {
      "type": "sse",
      "url": "http://localhost:9121/sse"
    },
    "codebase-memory-mcp": {
      "type": "stdio",
      "command": "bash",
      "args": ["infra/scripts/cbm-mcp.sh"],
      "env": {
        "NAVIGATION_BACKEND": "cbm"
      }
    }
  }
}