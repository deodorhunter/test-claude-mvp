# Database (PostgreSQL with asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aiplatform

# Redis
REDIS_URL=redis://localhost:6379/0

# Security — generate with: openssl rand -hex 32
SECRET_KEY=

# Plone backend URL (internal Docker network URL in production)
PLONE_BASE_URL=http://localhost:8080

# Qdrant vector database
QDRANT_URL=http://localhost:6333

# CORS allowed origins (JSON array)
CORS_ORIGINS=["http://localhost:3000"]

# Environment: development | production
ENVIRONMENT=development

# Token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Docker Compose local dev ---
# PostgreSQL container settings (used in docker-compose.yml interpolation)
POSTGRES_DB=aiplatform
POSTGRES_USER=aiplatform
POSTGRES_PASSWORD=
