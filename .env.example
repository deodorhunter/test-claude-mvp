# Database (PostgreSQL with asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aiplatform

# Redis
REDIS_URL=redis://localhost:6379/0

# Security — generate with: openssl rand -hex 32
SECRET_KEY=

# Plone backend URL (internal Docker network URL in production)
PLONE_BASE_URL=http://localhost:8080/Plone

# Plone credentials (used by plone-mcp service and Python adapter)
PLONE_USERNAME=admin
PLONE_PASSWORD=

# Plone MCP self-hosted server URL (internal Docker: http://plone-mcp:9120)
PLONE_MCP_URL=http://localhost:9120

# Qdrant vector database
QDRANT_URL=http://localhost:6333

# CORS allowed origins (JSON array)
CORS_ORIGINS=["http://localhost:3000"]

# Environment: development | production
ENVIRONMENT=development

# Token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI model settings (dev: tinyllama for fast integration tests; prod: llama3)
AI_MODE=demo
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=tinyllama

# --- Navigation backend (Claude Code MCP config) ---
# NAVIGATION_BACKEND is NOT set here — it lives in .claude/settings.json
# → mcpServers.codebase-memory-mcp.env.NAVIGATION_BACKEND (serena | cbm | both)
# Developer override (no file edit): export NAVIGATION_BACKEND=cbm before launching Claude Code
# See docs/NAVIGATION_BACKENDS.md for full config guide.

# --- Docker Compose local dev ---
# PostgreSQL container settings (used in docker-compose.yml interpolation)
POSTGRES_DB=aiplatform
POSTGRES_USER=aiplatform
POSTGRES_PASSWORD=
